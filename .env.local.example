# ─── Contact form / Resend ────────────────────────────────────────────
#
# Copy this file to `.env.local` and fill in your Resend credentials.
# The contact form at /contact sends two emails per submission: a
# studio notification and a visitor autoresponder, both rendered via
# React Email templates in /emails.
#
# 1. Create a free account at https://resend.com  (100 emails/day free)
# 2. Create an API key at https://resend.com/api-keys
# 3. (Optional) verify a sending domain at https://resend.com/domains
#    — until you do, use the sandbox address shown below, which only
#    delivers to the email address you signed up with.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity. Must be from a verified domain, OR the Resend
# sandbox "onboarding@resend.dev" during development.
RESEND_FROM="KATHA Studio <onboarding@resend.dev>"

# Inbox that receives new enquiry notifications.
STUDIO_EMAIL=neha@kathastudio.co
